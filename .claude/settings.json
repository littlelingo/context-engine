{
  "permissions": {
    "allow": [
      "Read(**)",
      "Glob(**)",
      "Grep(**)",
      "Bash(find:*)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(cat:*)",
      "Bash(git:diff*)",
      "Bash(git:log*)",
      "Bash(git:status*)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  },
  "env": {
    "PATH": "/Users/clint/.nvm/versions/node/v24.13.1/bin:/usr/local/bin:/usr/bin:/bin",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "0",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "git",
        "url": "https://github.com/anthropics/skills.git",
        "ref": "main"
      }
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/scripts/guard-protected-files.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/scripts/block-destructive.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/scripts/require-validation.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/scripts/auto-format.sh"
          }
        ]
      },                                                                                                                                                       
      {                                                                                                                                                       
        "matcher": "Read|Bash",                                                                                                                               
        "hooks": [                                                                                                                                            
          {                                               
            "type": "command",                                                                                                                                
            "command": "hooks/scripts/context-budget.sh"                                                                                                      
          }                                                                                                                                                   
        ]                
      },
      {
        "matcher": "mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/scripts/mcp-output-advisor.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "hooks/scripts/preserve-context.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "hooks/scripts/capture-learnings.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "hooks/scripts/verify-metrics.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "hooks/scripts/verify-agent-output.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "hooks/scripts/session-track.sh"
          }
        ]
      },                                                                                                                                                       
      {                                
        "hooks": [                                                                                                                                            
          {                                                                                                                                                 
            "type": "command",                            
            "command": "hooks/scripts/classify-request.sh"
          }                                                                                                                                                   
        ]  
      }
    ]
  }
}
